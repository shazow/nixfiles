#!/usr/bin/env python3
from __future__ import annotations

from collections import deque
from dataclasses import dataclass
from pathlib import Path
import os
import pwd
import time

INTERVAL = 1.0
PROCESS_WINDOW_SECONDS = 10.0
TOP_N = 14
CMD_WIDTH = 72


def read_int(path: Path) -> int | None:
    try:
        return int(path.read_text().strip())
    except Exception:
        return None


def read_str(path: Path) -> str | None:
    try:
        return path.read_text().strip()
    except Exception:
        return None


def read_cmdline(pid: int) -> str:
    try:
        raw = Path(f"/proc/{pid}/cmdline").read_bytes()
        parts = [p.decode("utf-8", "replace") for p in raw.split(b"\0") if p]
        return " ".join(parts)
    except Exception:
        return ""


def find_hwmon_by_name(name: str) -> Path | None:
    for h in Path("/sys/class/hwmon").glob("hwmon*"):
        if read_str(h / "name") == name:
            return h
    return None


def battery_watts() -> float | None:
    bat = Path("/sys/class/power_supply/BAT1")

    p = read_int(bat / "power_now")
    if p is not None:
        return p / 1e6

    v = read_int(bat / "voltage_now")
    c = read_int(bat / "current_now")
    if v is not None and c is not None:
        return (v * c) / 1e12

    return None


def battery_status() -> str:
    return read_str(Path("/sys/class/power_supply/BAT1/status")) or "unknown"


def amdgpu_ppt() -> tuple[float | None, float | None]:
    h = find_hwmon_by_name("amdgpu")
    if not h:
        return None, None

    inst = read_int(h / "power1_input")
    avg = read_int(h / "power1_average")

    inst_w = inst / 1e6 if inst is not None else None
    avg_w = avg / 1e6 if avg is not None else None
    return inst_w, avg_w


def k10temp() -> float | None:
    h = find_hwmon_by_name("k10temp")
    if not h:
        return None

    t = read_int(h / "temp1_input")
    return t / 1000 if t is not None else None


def fan_rpm() -> int | None:
    for name in ("framework_laptop", "cros_ec"):
        h = find_hwmon_by_name(name)
        if h:
            rpm = read_int(h / "fan1_input")
            if rpm is not None:
                return rpm
    return None


def cros_ec_temps() -> list[tuple[str, float]]:
    h = find_hwmon_by_name("cros_ec")
    if not h:
        return []

    vals: list[tuple[str, float]] = []
    for t in sorted(h.glob("temp*_input")):
        label = read_str(h / t.name.replace("_input", "_label")) or t.name
        raw = read_int(t)

        # Ignore bogus fault-ish zero readings.
        if raw is None or raw <= 0:
            continue

        vals.append((label, raw / 1000))
    return vals


def parse_proc_stat(stat_text: str) -> tuple[str, str, int, int, int] | None:
    # /proc/<pid>/stat has comm in parentheses and may contain spaces.
    # Format: pid (comm) state ... utime field 14, stime field 15.
    try:
        lparen = stat_text.index("(")
        rparen = stat_text.rindex(")")
        comm = stat_text[lparen + 1 : rparen]
        rest = stat_text[rparen + 2 :].split()
        state = rest[0]
        utime = int(rest[11])
        stime = int(rest[12])
        starttime = int(rest[19])
        return comm, state, utime, stime, starttime
    except Exception:
        return None


def parse_status(path: Path) -> tuple[int | None, int | None, int | None]:
    uid = None
    voluntary = None
    involuntary = None

    try:
        for line in path.read_text().splitlines():
            if line.startswith("Uid:"):
                uid = int(line.split()[1])
            elif line.startswith("voluntary_ctxt_switches:"):
                voluntary = int(line.split()[1])
            elif line.startswith("nonvoluntary_ctxt_switches:"):
                involuntary = int(line.split()[1])
    except Exception:
        pass

    return uid, voluntary, involuntary


def parse_io(path: Path) -> tuple[int | None, int | None]:
    read_bytes = None
    write_bytes = None

    try:
        for line in path.read_text().splitlines():
            if line.startswith("read_bytes:"):
                read_bytes = int(line.split()[1])
            elif line.startswith("write_bytes:"):
                write_bytes = int(line.split()[1])
    except Exception:
        pass

    return read_bytes, write_bytes


def chrome_process_kind(comm: str, cmdline: str) -> str | None:
    haystack = f"{comm} {cmdline}".lower()
    if "chrome" not in haystack and "chromium" not in haystack:
        return None

    for part in cmdline.split():
        if part.startswith("--type="):
            return f"chrome:{part.removeprefix('--type=')}"

    return "chrome:browser"


def process_label(comm: str, cmdline: str) -> str:
    chrome_kind = chrome_process_kind(comm, cmdline)
    if chrome_kind:
        return chrome_kind

    if cmdline:
        argv0 = Path(cmdline.split()[0]).name
        return argv0 or comm

    return comm


def display_command(comm: str, cmdline: str) -> str:
    chrome_kind = chrome_process_kind(comm, cmdline)
    if chrome_kind:
        # Keep flags visible enough to distinguish renderer/gpu/network/extension-ish processes.
        return f"{chrome_kind} {cmdline}".strip()

    return cmdline or comm


@dataclass
class ProcSample:
    pid: int
    comm: str
    cmdline: str
    label: str
    display: str
    state: str
    uid: int | None
    utime: int
    stime: int
    starttime: int
    voluntary: int | None
    involuntary: int | None
    read_bytes: int | None
    write_bytes: int | None

    @property
    def cpu_ticks(self) -> int:
        return self.utime + self.stime

    @property
    def ctxt(self) -> int | None:
        if self.voluntary is None and self.involuntary is None:
            return None
        return (self.voluntary or 0) + (self.involuntary or 0)


@dataclass
class ProcDelta:
    pid: int
    label: str
    display: str
    user: str
    cpu_pct: float
    ctxt_s: float | None
    read_bps: float | None
    write_bps: float | None
    score: float


@dataclass
class GroupDelta:
    label: str
    count: int
    cpu_pct: float
    ctxt_s: float | None
    read_bps: float | None
    write_bps: float | None
    score: float


def sample_processes() -> dict[int, ProcSample]:
    out: dict[int, ProcSample] = {}

    for p in Path("/proc").iterdir():
        if not p.name.isdigit():
            continue

        pid = int(p.name)

        stat_text = read_str(p / "stat")
        if not stat_text:
            continue

        parsed = parse_proc_stat(stat_text)
        if parsed is None:
            continue

        comm, state, utime, stime, starttime = parsed
        cmdline = read_cmdline(pid)
        label = process_label(comm, cmdline)
        display = display_command(comm, cmdline)
        uid, voluntary, involuntary = parse_status(p / "status")
        read_bytes, write_bytes = parse_io(p / "io")

        out[pid] = ProcSample(
            pid=pid,
            comm=comm,
            cmdline=cmdline,
            label=label,
            display=display,
            state=state,
            uid=uid,
            utime=utime,
            stime=stime,
            starttime=starttime,
            voluntary=voluntary,
            involuntary=involuntary,
            read_bytes=read_bytes,
            write_bytes=write_bytes,
        )

    return out


def user_name(uid: int | None) -> str:
    if uid is None:
        return "?"
    try:
        return pwd.getpwuid(uid).pw_name
    except Exception:
        return str(uid)


def rate_delta(old: int | None, new: int | None, interval: float) -> float | None:
    if old is None or new is None:
        return None
    delta = new - old
    if delta < 0:
        return None
    return delta / interval


def suspicion_score(
    cpu_pct: float,
    ctxt_s: float | None,
    read_bps: float | None,
    write_bps: float | None,
) -> float:
    # CPU dominates, but frequent wakeups/context switches and I/O churn matter
    # because idle prevention often burns power disproportionally.
    score = cpu_pct
    if ctxt_s is not None:
        score += min(ctxt_s / 100.0, 20.0)
    if read_bps is not None:
        score += min(read_bps / (20 * 1024 * 1024), 10.0)
    if write_bps is not None:
        score += min(write_bps / (20 * 1024 * 1024), 10.0)
    return score


def process_deltas_over_window(
    samples: deque[tuple[float, dict[int, ProcSample]]],
) -> list[ProcDelta]:
    if len(samples) < 2:
        return []

    start_t, old_samples = samples[0]
    end_t, cur_samples = samples[-1]
    interval = max(end_t - start_t, 0.001)

    clk_tck = os.sysconf(os.sysconf_names["SC_CLK_TCK"])
    rows: list[ProcDelta] = []

    for pid, now in cur_samples.items():
        old = old_samples.get(pid)
        if old is None:
            continue

        # Avoid comparing against a reused PID.
        if old.starttime != now.starttime:
            continue

        cpu_ticks = now.cpu_ticks - old.cpu_ticks
        if cpu_ticks < 0:
            continue

        # 100% = one fully busy CPU core.
        cpu_pct = 100.0 * cpu_ticks / clk_tck / interval
        ctxt_s = rate_delta(old.ctxt, now.ctxt, interval)
        read_bps = rate_delta(old.read_bytes, now.read_bytes, interval)
        write_bps = rate_delta(old.write_bytes, now.write_bytes, interval)
        score = suspicion_score(cpu_pct, ctxt_s, read_bps, write_bps)

        if score <= 0:
            continue

        rows.append(
            ProcDelta(
                pid=pid,
                label=now.label,
                display=now.display,
                user=user_name(now.uid),
                cpu_pct=cpu_pct,
                ctxt_s=ctxt_s,
                read_bps=read_bps,
                write_bps=write_bps,
                score=score,
            )
        )

    return sorted(rows, key=lambda r: r.score, reverse=True)


def none_add(a: float | None, b: float | None) -> float | None:
    if a is None and b is None:
        return None
    return (a or 0.0) + (b or 0.0)


def group_deltas(rows: list[ProcDelta]) -> list[GroupDelta]:
    grouped: dict[str, GroupDelta] = {}

    for r in rows:
        cur = grouped.get(r.label)
        if cur is None:
            grouped[r.label] = GroupDelta(
                label=r.label,
                count=1,
                cpu_pct=r.cpu_pct,
                ctxt_s=r.ctxt_s,
                read_bps=r.read_bps,
                write_bps=r.write_bps,
                score=r.score,
            )
            continue

        cur.count += 1
        cur.cpu_pct += r.cpu_pct
        cur.ctxt_s = none_add(cur.ctxt_s, r.ctxt_s)
        cur.read_bps = none_add(cur.read_bps, r.read_bps)
        cur.write_bps = none_add(cur.write_bps, r.write_bps)
        cur.score += r.score

    return sorted(grouped.values(), key=lambda r: r.score, reverse=True)


def fmt_w(v: float | None) -> str:
    return f"{v:6.2f} W" if v is not None else "   n/a "


def fmt_temp(v: float | None) -> str:
    return f"{v:6.1f} °C" if v is not None else "   n/a  "


def fmt_rate_bytes(v: float | None) -> str:
    if v is None:
        return "     ?"
    units = ["B/s", "K/s", "M/s", "G/s"]
    x = float(v)
    for unit in units:
        if abs(x) < 1024 or unit == units[-1]:
            return f"{x:5.1f}{unit}"
        x /= 1024
    return f"{x:5.1f}G/s"


def fmt_rate(v: float | None) -> str:
    return f"{v:7.0f}/s" if v is not None else "      ?"


def truncate(s: str, n: int) -> str:
    if len(s) <= n:
        return s
    return s[: max(0, n - 1)] + "…"


def render(samples: deque[tuple[float, dict[int, ProcSample]]]) -> None:
    bat_w = battery_watts()
    bat_st = battery_status()
    ppt_inst, ppt_avg = amdgpu_ppt()
    cpu_temp = k10temp()
    rpm = fan_rpm()
    ec_temps = cros_ec_temps()
    suspects = process_deltas_over_window(samples)
    groups = group_deltas(suspects)

    window_seconds = 0.0
    if len(samples) >= 2:
        window_seconds = samples[-1][0] - samples[0][0]

    print("\033[2J\033[H", end="")
    print("Framework 13 AMD power monitor")
    print()

    print(f"Battery/system:       {fmt_w(bat_w)}   {bat_st}")
    print(f"APU PPT instant:      {fmt_w(ppt_inst)}")
    print(f"APU PPT average:      {fmt_w(ppt_avg)}")
    print(f"CPU Tctl:             {fmt_temp(cpu_temp)}")
    if rpm is not None:
        print(f"Fan:                  {rpm:6d} RPM")
    else:
        print("Fan:                     n/a")

    if ec_temps:
        print()
        for label, val in ec_temps:
            print(f"EC {truncate(label, 18):18s} {val:6.1f} °C")

    print()
    print(f"Top suspect groups over {window_seconds:0.1f}s — inferred, not measured per-process watts")
    print()
    print(f"{'GROUP':24s} {'N':>3s} {'CPU%':>7s} {'CTXT':>10s} {'READ':>10s} {'WRITE':>10s}")
    print("-" * 76)

    for r in groups[:8]:
        print(
            f"{truncate(r.label, 24):24s} "
            f"{r.count:3d} "
            f"{r.cpu_pct:6.1f}% "
            f"{fmt_rate(r.ctxt_s):>10s} "
            f"{fmt_rate_bytes(r.read_bps):>10s} "
            f"{fmt_rate_bytes(r.write_bps):>10s}"
        )

    print()
    print(f"Top processes over {window_seconds:0.1f}s")
    print()
    print(f"{'PID':>7s} {'USER':10s} {'CPU%':>7s} {'CTXT':>10s} {'READ':>10s} {'WRITE':>10s}  CMD")
    print("-" * 76)

    for r in suspects[:TOP_N]:
        print(
            f"{r.pid:7d} "
            f"{truncate(r.user, 10):10s} "
            f"{r.cpu_pct:6.1f}% "
            f"{fmt_rate(r.ctxt_s):>10s} "
            f"{fmt_rate_bytes(r.read_bps):>10s} "
            f"{fmt_rate_bytes(r.write_bps):>10s}  "
            f"{truncate(r.display, CMD_WIDTH)}"
        )


def main() -> None:
    samples: deque[tuple[float, dict[int, ProcSample]]] = deque()

    while True:
        now = time.monotonic()
        samples.append((now, sample_processes()))

        # Keep roughly the last PROCESS_WINDOW_SECONDS of process samples.
        while samples and now - samples[0][0] > PROCESS_WINDOW_SECONDS:
            samples.popleft()

        render(samples)
        time.sleep(INTERVAL)


if __name__ == "__main__":
    main()

