#!/usr/bin/env sh
# Wrapper around `light` except turns off screen past 0

: "${OUTPUT_DEVICE:="auto"}" # or "eDP-1"
: "${AMOUNT:="10"}"
#
# Default values, feel free to override here or via environment variables
: "${NOTIFY_ID_PATH:=${TMPDIR:=/tmp}/brightness.$USER}"
: "${NOTIFY_ID:=$(cat $NOTIFY_ID_PATH)}"
: "${NOTIFY_TIMEOUT:=1500}"
: "${NOTIFY_ICON:="display-brightness-symbolic"}"
: "${NOTIFY_CATEGORY:="display"}"

notify() {
	notify-send \
		--category="${NOTIFY_CATEGORY}" \
		--expire-time="${NOTIFY_TIMEOUT}" \
		--icon="${NOTIFY_ICON}" \
		--replace-id="${NOTIFY_ID:=0}" \
		--print-id \
		--hint="$2" \
		"$1" > ${NOTIFY_ID_PATH}
}

if [ "$OUTPUT_DEVICE" = "auto" ]; then
    # Sway edition:
    # OUTPUT_DEVICE="$(swaymsg -t get_outputs | jq .[0].name)"
    OUTPUT_DEVICE="$(niri msg -j focused-output | jq -r .name)"
fi

if [ "$2" ]; then
    # Override env AMOUNT because it's annoying to pass env vars into sway bindings
    AMOUNT="$2"
fi

# Check if light returns a warning
if light -G 2>&1 1>/dev/null | grep -q "No backlight controller was found"; then
    echo "No controller found, exiting."
    exit 1
fi

readonly old="$(light -G)"

case $1 in
    up)
        if [ "$old" = "0.00" ]; then
            # wlopm requires wlr-output-power-management-unstable-v1.h, which niri doesn't implement yet T_T
            wlopm --on "$OUTPUT_DEVICE"
        fi
        # FIXME: There's a bug here where we'll double-up after breaking out of 0, meh
        light -A "$AMOUNT"
    ;;
    down)
        if [ "$old" = "0.00" ]; then
            wlopm --off "$OUTPUT_DEVICE"
        else
            light -U "$AMOUNT"
        fi
    ;;
esac

new="$(light -G)"
echo "Brightness adjusted for $OUTPUT_DEVICE: $old -> $new"
notify "${VOLUME_LABEL}" "int:value:${new%.*}"
